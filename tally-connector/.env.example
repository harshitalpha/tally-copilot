# ── Where is the backend? ─────────────────────────────────────────────
# The connector runs on the Windows/Tally machine. It must REACH the backend.
# "localhost" only works if the backend runs on this SAME machine.
#
#   • Backend on another machine on the same WiFi:
#       BACKEND_URL=http://192.168.1.50:8000      (the backend machine's LAN IP)
#   • Backend deployed to the cloud:
#       BACKEND_URL=https://your-app.up.railway.app
BACKEND_URL=http://localhost:8000

# ── Where is Tally? ───────────────────────────────────────────────────
# Tally's HTTP gateway, on THIS machine. Default port is 9000.
# Enable it in Tally: F1 (Help) → Settings → Connectivity →
#   Client/Server configuration → "TallyPrime acts as" = Both, Port = 9000
TALLY_URL=http://localhost:9000

POLL_INTERVAL_SECONDS=10
